<nav class="navbar navbar-expand-lg">
    <div class="container">
        <a class="navbar-brand" href="/">ANI<span>BASE</span></a>
        <div class="d-flex gap-3">
            <a class="nav-link" href="/anime">Anime</a>
            <a class="nav-link" href="/characters">Characters</a>
            <a class="nav-link" href="/people">People</a>
            <a class="nav-link" href="/users">Users</a>
        </div>
    </div>
</nav>

<div class="container py-4">
    <div class="container pt-2 pb-2">
        <p class="section-label mb-1">Directory</p>
        <h4 class="mb-3">Users</h4>
    </div>
    <div class="row g-2 mb-4">
        <div class="col-md-4">
            <input type="text" id="usernameInput" class="form-control" placeholder="Search by username...">
        </div>
        <div class="col-md-3">
            <input type="text" id="locationInput" class="form-control" placeholder="Filter by location...">
        </div>
        <div class="col-md-2">
            <input type="number" id="yearInput" class="form-control" placeholder="Joined year...">
        </div>
        <div class="col-auto">
            <button id="searchBtn" class="btn btn-dark">Search</button>
        </div>
    </div>
    <div id="resultsTable"></div>
    <div id="pagination" class="mt-4"></div>
</div>

<script>
    let currentPage = 0;
    const PAGE_SIZE = 30;

    function renderTable(users) {
        if (!users.length) return '<p class="text-muted">No users found.</p>';
        return `<table class="table table-hover table-sm">
            <thead class="table-light"><tr>
                <th>Username</th><th>Gender</th><th>Location</th><th>Joined</th>
            </tr></thead>
            <tbody>${users.map(u => `
                <tr onclick="window.location='/users/${u.username}'">
                    <td><strong>${u.username}</strong></td>
                    <td>${u.gender||'—'}</td>
                    <td>${u.location||'—'}</td>
                    <td>${u.joined||'—'}</td>
                </tr>`).join('')}
            </tbody></table>`;
    }

    async function load(page = 0) {
        currentPage = page;
        document.getElementById('resultsTable').innerHTML = '<div class="text-center py-3"><div class="spinner-border"></div></div>';
        const username = document.getElementById('usernameInput').value.trim();
        const location = document.getElementById('locationInput').value.trim();
        const year     = document.getElementById('yearInput').value.trim();

        try {
            let data;
            if (username) {
                const user = await api.getUserByUsername(username);
                data = { content: [user], page: { totalPages: 1 } };
            } else if (location) {
                data = await api.getUsersByLocation(location, page, PAGE_SIZE);
            } else if (year) {
                data = await fetch(`/api/users/joined/${year}?page=${page}&size=${PAGE_SIZE}`).then(r => r.json());
            } else {
                data = await fetch(`/api/users?page=${page}&size=${PAGE_SIZE}`).then(r => r.json());
            }
            const items = data.content || [];
            const total = data.page?.totalPages || 1;
            document.getElementById('resultsTable').innerHTML = renderTable(items);
            renderPagination('pagination', currentPage, total, load);
        } catch(e) {
            showError('resultsTable', 'User not found');
        }
    }

    document.getElementById('searchBtn').addEventListener('click', () => load(0));
    document.getElementById('usernameInput').addEventListener('keydown', e => { if (e.key === 'Enter') load(0); });
    document.getElementById('locationInput').addEventListener('keydown', e => { if (e.key === 'Enter') load(0); });
    load(0);
</script>