<nav class="navbar navbar-expand-lg">
    <div class="container">
        <a class="navbar-brand" href="/">ANI<span>BASE</span></a>
        <div class="d-flex gap-3">
            <a class="nav-link" href="/anime">Anime</a>
            <a class="nav-link" href="/characters">Characters</a>
            <a class="nav-link" href="/people">People</a>
            <a class="nav-link" href="/users">Users</a>
        </div>
    </div>
</nav>

<div class="container py-4">
    <div id="content"><div class="text-center py-5"><div class="spinner-border"></div></div></div>
</div>

<script>
    const id = window.location.pathname.split('/').pop();
    if (!id) window.location.href = '/characters';

    api.getCharacterById(id).then(c => {
        document.getElementById('content').innerHTML = `
            <div class="row g-4">
                <div class="col-md-3 text-center">
                    <img src="${c.imageUrl||'https://via.placeholder.com/225x320'}" class="img-fluid rounded shadow" alt="${c.name}">
                    <div class="mt-3">
                        <div class="fs-5 fw-bold">♥ ${(c.favorites||0).toLocaleString()}</div>
                        <small class="text-muted">favorites</small>
                    </div>
                </div>
                <div class="col-md-9">
                    <h2 class="fw-bold">${c.name}</h2>
                    <p class="text-muted">${c.nameKanji||''}</p>
                    <p class="text-secondary mt-3" style="white-space:pre-line">${c.about||'No information available.'}</p>
                </div>
            </div>`;
    }).catch(() => showError('content', 'Failed to load character'));
</script>