<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <p class="section-label mb-1">Rankings</p>
            <h4 class="mb-0">Top Anime by Score</h4>
        </div>
        <a href="/anime" class="btn btn-dark">View All</a>
    </div>
    <div id="topAnimeGrid" class="row row-cols-2 row-cols-sm-3 row-cols-md-4 row-cols-lg-6 g-3">
        <div class="text-center py-4 col-12"><div class="spinner-border"></div></div>
    </div>
</div>

<script>
    const container = document.getElementById('speedLines');
    for (let i = 0; i < 18; i++) {
        const line = document.createElement('div');
        line.className = 'speed-line';
        line.style.cssText = `
            top: ${Math.random() * 100}%;
            width: ${60 + Math.random() * 200}px;
            animation-delay: ${Math.random() * 2.4}s;
            animation-duration: ${1.8 + Math.random() * 1.5}s;
            opacity: ${0.3 + Math.random() * 0.5};
        `;
        container.appendChild(line);
    }

    document.getElementById('searchForm').addEventListener('submit', e => {
        e.preventDefault();
        const q = document.getElementById('searchInput').value.trim();
        if (q) window.location.href = `/anime?q=${encodeURIComponent(q)}`;
    });

    api.getTopByScore(0, 12).then(data => {
        const items = data.content || data;
        document.getElementById('topAnimeGrid').innerHTML = items.map(animeCard).join('');
    }).catch(() => showError('topAnimeGrid', 'Failed to load anime'));
</script>