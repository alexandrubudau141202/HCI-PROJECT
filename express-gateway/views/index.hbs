<div class="hero">
    <div class="speed-lines" id="speedLines"></div>
    <div class="container position-relative" style="z-index:1">
        <p class="section-label mb-3">28,000+ Series · 209,000+ Characters · 123M+ Ratings</p>
        <h1>The<br><em>Anime</em><br>Database</h1>
        <p class="mt-3 mb-4">Full throttle through every series, character and voice actor</p>
        <form id="searchForm" class="row g-2">
            <div class="col-md-6">
                <input type="text" id="searchInput" class="form-control form-control-lg" placeholder="Search anime...">
            </div>
