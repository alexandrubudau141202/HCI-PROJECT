<nav class="navbar navbar-expand-lg">
    <div class="container">
        <a class="navbar-brand" href="/">ANI<span>BASE</span></a>
        <div class="d-flex gap-3">
            <a class="nav-link" href="/anime">Anime</a>
            <a class="nav-link" href="/characters">Characters</a>
            <a class="nav-link" href="/people">People</a>
            <a class="nav-link" href="/users">Users</a>
        </div>
    </div>
</nav>

<div class="container py-4">
    <div id="content"><div class="text-center py-5"><div class="spinner-border"></div></div></div>
</div>

<script>
    const id = window.location.pathname.split('/').pop();
    if (!id) window.location.href = '/people';

    api.getPersonById(id).then(p => {
        document.getElementById('content').innerHTML = `
            <div class="row g-4">
                <div class="col-md-3 text-center">
                    <img src="${p.imageUrl||'https://via.placeholder.com/225x320'}" class="img-fluid rounded shadow" alt="${p.name}">
                    <div class="mt-3">
                        <div class="fs-5 fw-bold">♥ ${(p.favorites||0).toLocaleString()}</div>
                        <small class="text-muted">favorites</small>
                    </div>
                </div>
                <div class="col-md-9">
                    <h2 class="fw-bold">${p.name}</h2>
                    <p class="text-muted">${[p.givenName, p.familyName].filter(Boolean).join(' ')}</p>
                    <div class="row g-2 mt-1 small">
                        ${p.birthday ? `<div class="col-auto"><strong>Birthday:</strong> ${p.birthday}</div>` : ''}
                        ${p.relevantLocation ? `<div class="col-auto"><strong>Location:</strong> ${p.relevantLocation}</div>` : ''}
                    </div>
                </div>
            </div>`;
    }).catch(() => showError('content', 'Failed to load person'));
</script>